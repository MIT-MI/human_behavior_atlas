+                oldest = next(iter(self._lazy_binary_cache))
+                del self._lazy_binary_cache[oldest]
+            import pandas as pd
+            schema = pq.read_schema(filepath)
+            available_binary = [c for c in self._BINARY_COLUMNS if c in schema.names]
+            if available_binary:
+                self._lazy_binary_cache[file_idx] = pd.read_parquet(filepath, columns=available_binary)
+            else:
