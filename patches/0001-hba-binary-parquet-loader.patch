+        filepath = self._lazy_file_paths[file_idx]
+
+        # Cache lightweight columns (text/metadata) — very small, cache all files
+        if file_idx not in self._lazy_meta_cache:
+            if self._lazy_cache_max > 0 and len(self._lazy_meta_cache) >= self._lazy_cache_max:
+                oldest = next(iter(self._lazy_meta_cache))
+                del self._lazy_meta_cache[oldest]
+            # Read only text columns — fast, ~1MB per file instead of ~500MB
+            schema = pq.read_schema(filepath)
+            available_light = [c for c in self._LIGHT_COLUMNS if c in schema.names]
+            self._lazy_meta_cache[file_idx] = pq.read_table(filepath, columns=available_light)
+
+        # Get text/metadata from cache
+        meta_table = self._lazy_meta_cache[file_idx]
+        row_dict = {}
+        for col in meta_table.column_names:
+            row_dict[col] = meta_table.column(col)[local_row].as_py()
+
+        # Read binary columns from a separately cached full DataFrame
+        # (kept in an LRU cache of 4 files to avoid constant reloading)
+        if not hasattr(self, '_lazy_binary_cache'):
